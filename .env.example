# ============================================================
# Core Infrastructure
# ============================================================

DATABASE_URL=postgres://hahi:hahi@localhost:5432/hahi
REDIS_URL=redis://localhost:6379

# S3-compatible object storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=hahi
S3_SECRET_KEY=hahiminio
S3_BUCKET=hahi

# ============================================================
# Observability
# ============================================================

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
RUST_LOG=info

# ============================================================
# LLM Providers (configure at least one)
# ============================================================

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ============================================================
# Services
# ============================================================

GATEWAY_PORT=3000
AGENT_WORKER_COUNT=4

# External services (gRPC) — only services the agent doesn't own directly.
# Memory and skill are internal to the agent (direct PG access).
BILLING_SERVICE_ADDR=127.0.0.1:50054
CHAT_SERVICE_ADDR=127.0.0.1:50051
